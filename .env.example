# ──────────────────────────────────────────────────────────────────
#  ZapDin PDV — Configuração
#  Renomeie para .env e preencha os valores.
# ──────────────────────────────────────────────────────────────────

# Evolution API rodando LOCALMENTE nesta máquina (porta padrão 8080)
# O WhatsApp conecta aqui — usa CPU/memória desta máquina, não do servidor
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=zapdin-pdv-local

# ZapDin App REMOTO — token de máquina (sem usuário/senha)
# Gere o token no App: POST /api/pdv/tokens  ou pelo painel do App
# Cole o token gerado abaixo:
ZAPDIN_URL=https://app.seuservidor.com.br
ZAPDIN_PDV_TOKEN=pdv_xxxxxxxxxxxxxxxxxxxx

# Porta local do PDV (ERP chama http://localhost:4600)
PDV_PORT=4600

# Chave de segurança — ERP envia no header X-PDV-Key
PDV_API_KEY=minha-chave-pdv-123

# Nome identificador deste PDV (aparece no status e no App)
PDV_NOME=Caixa 01
